<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CsjAds.Sample.Pages.InterstitialPage"
             Title="Interstitial">

    <VerticalStackLayout Spacing="16" Padding="24">
        <Label Text="Interstitial (Full-Screen) Ad" FontSize="20" FontAttributes="Bold" />

        <Entry x:Name="SlotIdEntry" Placeholder="Enter slot ID" Text="945113160" />

        <Button Text="Load Ad" Clicked="OnLoadAd"
                BackgroundColor="#7E57C2" TextColor="White" />

        <Button x:Name="ShowButton" Text="Show Ad" Clicked="OnShowAd"
                BackgroundColor="#43A047" TextColor="White" IsEnabled="False" />

        <Label x:Name="LogLabel" Text="Ready" FontSize="12" TextColor="Gray" />
    </VerticalStackLayout>

</ContentPage>
